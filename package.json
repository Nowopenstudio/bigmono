{
  "name": "bigstore",
  "private": false,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm -r dev",
    "build": "npm -r build",
    "postinstall": "node -e \"const fs=require('node:fs'); const p='scripts/patch-opennext-manifest-loader.js'; if(fs.existsSync(p)){ require('./'+p) } else { console.log('[postinstall] skip opennext patch (script not present in this build stage)') }\"",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ],
  "overrides": {},
  "dependencies": {
    "@dtc/opennext-bin-shim": "file:tools/opennext-bin-shim",
    "@medusajs/cli": "2.14.0",
    "@medusajs/framework": "2.14.0",
    "@medusajs/medusa": "2.14.0",
    "@opennextjs/cloudflare": "^1.19.4",
    "@medusajs/ui": "^4.1.8",
    "lenis": "^1.3.23",
    "motion": "^12.38.0",
    "wrangler": "^4.85.0"
  }
}
